# ============================================
# Cloud App (set these on Render)
# ============================================
DATABASE_URL=postgresql://user:pass@host:5432/dbname
SECRET_KEY=your-secret-key-here
WORKER_API_KEY=your-worker-api-key-here

# ============================================
# Local Worker (set these on your laptop)
# ============================================
SERVER_URL=https://your-app.onrender.com
WORKER_API_KEY=same-key-as-above

# ============================================
# Hardware (worker only)
# ============================================
CAMERA_SOURCE=auto
ESP32_CAM_IP=192.168.1.100
ESP32_SIMULATION=true
FACE_DETECTION_MODEL=hog
FACE_RECOGNITION_TOLERANCE=0.5
